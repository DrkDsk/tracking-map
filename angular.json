{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": "a0a61f7e-8807-49db-8c3c-abd14b004d93"
  },
  "newProjectRoot": "projects",
  "projects": {
    "tracking-sdk": {
      "projectType": "library",
      "root": "projects/tracking-sdk",
      "sourceRoot": "projects/tracking-sdk/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/tracking-sdk/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/tracking-sdk/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/tracking-sdk/tsconfig.spec.json"
          }
        }
      }
    },
    "tracking-map": {
      "projectType": "library",
      "root": "projects/tracking-map",
      "sourceRoot": "projects/tracking-map/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/tracking-map/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/tracking-map/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/tracking-map/tsconfig.spec.json"
          }
        }
      }
    },
    "tracking-map-demo": {
      "projectType": "application",
      "schematics": {},
      "root": "projects/tracking-map-demo",
      "sourceRoot": "projects/tracking-map-demo/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "projects/tracking-map-demo/src/main.ts",
            "tsConfig": "projects/tracking-map-demo/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/tracking-map-demo/public"
              }
            ],
            "styles": ["projects/tracking-map-demo/src/styles.css"]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "tracking-map-demo:build:production"
            },
            "development": {
              "buildTarget": "tracking-map-demo:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    },
    "tracking-video": {
      "projectType": "library",
      "root": "projects/tracking-video",
      "sourceRoot": "projects/tracking-video/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/tracking-video/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/tracking-video/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/tracking-video/tsconfig.spec.json"
          }
        }
      }
    }
  }
}
