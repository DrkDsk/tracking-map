{
  "name": "tracking-plugin",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "config": "node ./projects/tracking-map/config/set-env.config.js",
    "dev": "concurrently \"ng build tracking-map --watch\" \"ng serve tracking-map-demo\"",
    "build:lib": "npm run config && ng build tracking-map",
    "start": "ng serve",
    "build": "ng build tracking-map-demo",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@maplibre/ngx-maplibre-gl": "^21.0.2",
    "dotenv": "^17.4.2",
    "laravel-echo": "^2.3.4",
    "maplibre-gl": "^5.24.0",
    "pusher-js": "^8.5.0",
    "rxjs": "~7.8.0",
    "socket.io-client": "^4.8.3",
    "tslib": "^2.3.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.12",
    "@angular/cli": "^21.2.12",
    "@angular/compiler-cli": "^21.2.0",
    "concurrently": "^9.2.1",
    "jsdom": "^28.0.0",
    "ng-packagr": "^21.2.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
